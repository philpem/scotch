#!/usr/bin/env bash
#
# replay-make: build an Acorn Replay movie from any video file in one command,
# wrapping ffmpeg, replay-encode and replay-join. Intermediate frame/audio/poster
# files are written to a temporary directory and removed on exit.
#
#   replay-make INPUT OUTPUT,ae7 [options]
#
# Options (defaults in brackets):
#   --codec N          video codec: 19 Super Moving Blocks 6Y5UV (default),
#                      17 Moving Blocks HQ YUV 5,5,5, 7 Moving Blocks YUV 5,5,5,
#                      20 Moving Blocks Beta 6Y6UV
#   --variant V        type 20 only: old (direct 6-bit chroma, the 20 Sep 1996
#                      module, default) or new (delta-coded, 19 Nov 1996)
#   --type-alias N     write compression type N in the container instead of the
#                      codec number, so a "type 20 new" movie can target a
#                      Decomp<N> install (free numbers: 13, 14, 28, 29, 30)
#   --dither MODE      ordered (Bayer) luma dither in RGB->YUV: 4x4 or 8x8
#                      [8x8]; breaks gradient banding at ~1 LSB of stable noise
#                      and ~4% size. 8x8 is finer/less visible than 4x4.
#   --no-dither        disable luma dither
#   --policy P         copy selection: ordered | lowest-error [lowest-error];
#                      lowest-error picks the least-error copy (cleaner edges)
#   --width N          output width in pixels [320]; height keeps aspect, /4
#   --fps F            output frame rate [12.5]
#   --loss-level N     quality 0 (exact) .. 28 (roughest) [10]
#   --frames-per-chunk N   frames per chunk [25]
#   --start SECONDS    start offset into the source [0]
#   --duration SECONDS encode only this many seconds [whole file]
#   --audio-rate HZ    sound sample rate [11025]
#   --audio-channels N audio channels 1 or 2 [1]
#   --no-audio         omit the sound track
#   --poster IMAGE     poster image (any ffmpeg-readable file) [first frame];
#                      pass --no-poster to embed nothing (command-line player only)
#   --no-poster        do not embed a poster sprite
#   --keys             emit per-chunk key frames so !ARPlayer can seek
#   --audio-format F   vidc-e8 (default) | signed-8 | signed-16 | adpcm | adpcm2
#   --title TEXT       movie title metadata
#   --data-rate KB     device-bandwidth mode: target kB/s of playback data;
#                      sets a per-frame byte budget (CompLib's formula)
#   --latency SECONDS  IO latency allowance for --data-rate [0.4]
#   --double           assume the player double-buffers chunks (with --data-rate)
#   --arm2-max N       cap the per-frame budget at N bytes ("Limit to ARM2")
#
set -euo pipefail

self=$(cd "$(dirname "$(readlink -f "$0")")" && pwd)
root=$(dirname "$self")
bin="${REPLAY_BIN:-$root/build-release}"
[ -x "$bin/replay-encode" ] || bin="$root/build"
if [ ! -x "$bin/replay-encode" ] || [ ! -x "$bin/replay-join" ]; then
    echo "replay-make: cannot find replay-encode/replay-join (set REPLAY_BIN)" >&2
    exit 1
fi

[ $# -ge 2 ] || { sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'; exit 1; }
input=$1; output=$2; shift 2

width=320; fps=12.5; loss=10; fpc=25; start=0; duration=
arate=11025; no_audio=0; poster=; no_poster=0; keys=0; aformat=vidc-e8; title=; achan=1; datarate=; latency=0.4; dblbuf=1; arm2max=; codec=19; dither=8x8; policy=; variant=old; typealias=
while [ $# -gt 0 ]; do
    case $1 in
        --codec)            codec=$2; shift 2;;
        --variant)          variant=$2; shift 2;;
        --type-alias)       typealias=$2; shift 2;;
        --dither)           dither=$2; shift 2;;
        --no-dither)        dither=; shift;;
        --policy)           policy=$2; shift 2;;
        --width)            width=$2; shift 2;;
        --fps)              fps=$2; shift 2;;
        --loss-level)       loss=$2; shift 2;;
        --frames-per-chunk) fpc=$2; shift 2;;
        --start)            start=$2; shift 2;;
        --duration)         duration=$2; shift 2;;
        --audio-rate)       arate=$2; shift 2;;
        --no-audio)         no_audio=1; shift;;
        --poster)           poster=$2; shift 2;;
        --no-poster)        no_poster=1; shift;;
        --keys)             keys=1; shift;;
        --audio-format)     aformat=$2; shift 2;;
        --title)            title=$2; shift 2;;
        --audio-channels)   achan=$2; shift 2;;
        --data-rate)        datarate=$2; shift 2;;
        --latency)          latency=$2; shift 2;;
        --double)           dblbuf=2; shift;;
        --arm2-max)         arm2max=$2; shift 2;;
        *) echo "replay-make: unknown option $1" >&2; exit 1;;
    esac
done

[ -f "$input" ] || { echo "replay-make: no such file: $input" >&2; exit 1; }

# Video codec selection: type 19 (Super Moving Blocks, 6Y5UV), type 17 (Moving
# Blocks HQ, YUV 5,5,5) or type 7 (Moving Blocks, YUV 5,5,5 -- the codec every
# RISC PC has as standard). They differ only in payload suffix and the ARMovie
# pixel-format label.
case $codec in
    19) vsuffix=mb19; vlabel=6Y5UV;;
    17) vsuffix=mb17; vlabel=YUV;;
    7)  vsuffix=mb7;  vlabel=YUV;;
    20) vsuffix=mb20; vlabel=6Y6UV;;
    *) echo "replay-make: --codec must be 7, 17, 19 or 20" >&2; exit 1;;
esac

# Type 20 has two shipped decoder revisions (--variant old|new, see
# docs/type20-shipped-vs-source.md). Pass the variant to the encoder, and let
# --type-alias write a different compression-type number in the container so the
# "new" (delta) module can be installed at Decomp<alias> beside the "old" one.
variantarg=()
[ "$codec" = 20 ] && variantarg=(--variant "$variant")
ctype=${typealias:-$codec}

# Source dimensions -> output height that keeps aspect and is a multiple of 4.
iw=$(ffprobe -v error -select_streams v:0 -show_entries stream=width \
    -of csv=p=0 "$input")
ih=$(ffprobe -v error -select_streams v:0 -show_entries stream=height \
    -of csv=p=0 "$input")
height=$(python3 -c "print(max(4, round($width*$ih/$iw/4)*4))")

work=$(mktemp -d)
trap 'rm -rf "$work"' EXIT

ss=(); [ "$start" != 0 ] && ss=(-ss "$start")
tt=(); [ -n "$duration" ] && tt=(-t "$duration")

echo "replay-make: ${width}x${height} @ ${fps}fps, loss $loss -> $output" >&2

# Device-bandwidth rate control: per-frame byte budget (Decomp19 BatchComp's
# formula) from the target data rate, IO latency, buffering and sound size.
targetarg=()
if [ -n "$datarate" ]; then
    target=$(python3 -c "
import math
fps=$fps; fpc=$fpc; rate=$arate; ch=$achan; dr=$datarate; lat=$latency; dbl=$dblbuf
fmt='$aformat'; noaudio=$no_audio
chunktime=fpc/fps
if noaudio: bps=0
elif fmt=='signed-16': bps=rate*ch*2
elif fmt in ('adpcm','adpcm2','adpcm-sounda4'): bps=rate*ch/2
else: bps=rate*ch
snd=math.ceil(bps*chunktime)
data=int((chunktime*dbl-lat)/dbl*dr*1024-snd) & ~1023
if data < 1024: data = 1024
fs=data // int(fpc)
am='$arm2max'
if am: fs=min(fs, int(am))
print(max(64, fs))")
    targetarg=(--target-bytes "$target")
    echo "replay-make: ${datarate}kB/s, latency ${latency}s, x${dblbuf} buffer -> ~${target} bytes/frame" >&2
fi

# Video: scale and frame-rate convert, encode each frame as a codec payload.
keyarg=(); [ "$keys" = 1 ] && keyarg=(--keys-prefix "$work/k-")
ditharg=(--no-dither); [ -n "$dither" ] && ditharg=(--dither "$dither")
polarg=(); [ -n "$policy" ] && polarg=(--policy "$policy")
ffmpeg -hide_banner -loglevel error "${ss[@]}" "${tt[@]}" -i "$input" \
    -vf "fps=$fps,scale=$width:$height:flags=lanczos" -pix_fmt rgb24 -f rawvideo - | \
    "$bin/replay-encode" --codec "$codec" "${variantarg[@]}" --input - \
        --size "${width}x${height}" \
        --payload-prefix "$work/f-" "${keyarg[@]}" "${targetarg[@]}" \
        "${ditharg[@]}" "${polarg[@]}" --loss-level "$loss" >/dev/null
frames=$(find "$work" -name "f-*.$vsuffix" | wc -l)
[ "$frames" -gt 0 ] || { echo "replay-make: no frames encoded" >&2; exit 1; }

args=(--codec "$ctype" --size "${width}x${height}" --fps "$fps"
      --frames-prefix "$work/f-" --frames "$frames" --frame-suffix ".$vsuffix"
      --frames-per-chunk "$fpc" --pixel-label "$vlabel")
[ "$keys" = 1 ] && args+=(--keys-prefix "$work/k-")

if [ "$no_audio" = 0 ]; then
    ffmpeg -hide_banner -loglevel error "${ss[@]}" "${tt[@]}" -i "$input" \
        -vn -ac "$achan" -ar "$arate" -f s16le "$work/a.pcm"
    args+=(--sound-pcm "$work/a.pcm" --sound-encode "$aformat"
           --sound-rate "$arate" --sound-channels "$achan")
fi

if [ "$no_poster" = 1 ]; then
    args+=(--no-poster)
elif [ -n "$poster" ]; then
    ffmpeg -hide_banner -loglevel error -i "$poster" \
        -vf "scale=$width:$height" -pix_fmt bgr555le -f rawvideo "$work/p.bin"
    args+=(--poster "$work/p.bin")
else
    # No image given: use the first encoded frame as the poster.
    ffmpeg -hide_banner -loglevel error "${ss[@]}" -i "$input" \
        -vf "scale=$width:$height" -frames:v 1 -pix_fmt bgr555le -f rawvideo "$work/p.bin"
    args+=(--poster "$work/p.bin")
fi

[ -n "$title" ] && args+=(--title "$title")
"$bin/replay-join" "${args[@]}" --output "$output"
